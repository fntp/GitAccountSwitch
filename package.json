{
  "name": "git-account-switcher",
  "displayName": "Git Account Switcher",
  "description": "Quickly switch between GitHub, Gitee and GitLab accounts globally",
  "version": "1.0.0",
  "publisher": "git-account-switcher",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "github",
    "gitee",
    "gitlab",
    "account",
    "switcher"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-account-switcher",
          "title": "Git Account Switcher",
          "icon": "$(person)"
        }
      ]
    },
    "views": {
      "git-account-switcher": [
        {
          "type": "webview",
          "id": "gitAccountSwitcher.view",
          "name": "Git Account Switcher"
        }
      ]
    },
    "commands": [
      {
        "command": "gitAccountSwitcher.refresh",
        "title": "Git Account Switcher: Refresh"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
